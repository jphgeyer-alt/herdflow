generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  fullName         String
  phone            String?
  passwordHash     String?
  role             UserRole @default(CUSTOMER)
  marketingConsent Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sellerProfile    Seller?
  logisticsProfile LogisticsPartner?
  orders           Order[]
  passwordResets   PasswordResetToken[]
  sessions         UserSession[]
}

model UserSession {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime  @default(now())
  userAgent  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  fullName     String
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions AdminUserSession[]
}

model AdminUserSession {
  id          String    @id @default(cuid())
  adminUserId String
  tokenHash   String    @unique
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  lastUsedAt  DateTime  @default(now())
  userAgent   String?

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

model AdminActivityLog {
  id          String   @id @default(cuid())
  adminUserId String?
  adminName   String
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([createdAt])
}

model Seller {
  id               String             @id @default(cuid())
  userId           String             @unique
  slug             String             @unique
  farmName         String
  location         String
  region           String
  contactPhone     String
  nationalIdNumber String
  idDocumentUrl    String
  status           VerificationStatus @default(PENDING)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  livestockListings Listing[]
  products          Product[]
  payouts           SellerPayout[]
}

model LogisticsPartner {
  id                  String             @id @default(cuid())
  userId              String             @unique
  companyName         String
  fleetSize           Int
  routesCovered       String
  vehicleDocumentsUrl String
  status              VerificationStatus @default(PENDING)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryRequests DeliveryRequest[]
  payouts          LogisticsPayout[]
}

model Category {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  kind      CategoryKind @default(BOTH)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  listings Listing[]
  products Product[]
}

model Listing {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  description  String
  priceCents   Int
  region       String
  breed        String
  weightKg     Int?
  ageMonths    Int?
  photos       String[]
  status       ListingStatus @default(ACTIVE)
  isFeatured   Boolean       @default(false)
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  deleteReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sellerId   String
  categoryId String

  seller   Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId, region])
  @@index([status, isFeatured])
  @@index([isDeleted, status])
}

model Product {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  description  String
  priceCents   Int
  stockOnHand  Int           @default(0)
  photos       String[]
  region       String?
  status       ProductStatus @default(ACTIVE)
  isFeatured   Boolean       @default(false)
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  deleteReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  sellerId   String?
  categoryId String

  seller     Seller?     @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([categoryId, status])
  @@index([sellerId, status])
}

model Order {
  id                 String      @id @default(cuid())
  orderNumber        String      @unique
  userId             String?
  guestEmail         String?
  status             OrderStatus @default(PENDING)
  totalCents         Int
  currency           String      @default("ZAR")
  paymentMethod      String      @default("PayFast")
  paymentReference   String?
  deliveryMethod     String      @default("PICKUP")
  shippingAddress    String?
  shippingCity       String?
  shippingProvince   String?
  shippingPostalCode String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  deliveryRequest DeliveryRequest?

  @@index([status, createdAt])
}

model ContactInquiry {
  id            String   @id @default(cuid())
  inquiryNumber String   @unique
  fullName      String
  email         String
  phone         String?
  subject       String
  message       String
  status        String   @default("NEW")
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  productId       String
  quantity        Int
  unitPriceCents  Int
  lineTotalCents  Int
  commissionCents Int     @default(0)
  payoutId        String?

  order   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])
  payout  SellerPayout? @relation(fields: [payoutId], references: [id])

  @@index([payoutId])
}

enum PayoutStatus {
  PENDING
  PAID
  CANCELLED
}

model SellerPayout {
  id               String       @id @default(cuid())
  number           String       @unique
  sellerId         String
  seller           Seller       @relation(fields: [sellerId], references: [id])
  amountCents      Int
  status           PayoutStatus @default(PENDING)
  paymentReference String?
  notes            String?
  createdBy        String
  paidAt           DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  items            OrderItem[]
}

enum DeliveryStatus {
  OPEN
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model DeliveryRequest {
  id                 String            @id @default(cuid())
  number             String            @unique
  orderId            String?           @unique
  order              Order?            @relation(fields: [orderId], references: [id])
  pickupAddress      String
  pickupRegion       String
  dropoffAddress     String
  dropoffRegion      String
  cargoDescription   String
  neededBy           DateTime?
  priceCents         Int
  commissionCents    Int               @default(0)
  status             DeliveryStatus    @default(OPEN)
  logisticsPartnerId String?
  logisticsPartner   LogisticsPartner? @relation(fields: [logisticsPartnerId], references: [id])
  assignedAt         DateTime?
  pickedUpAt         DateTime?
  deliveredAt        DateTime?
  payoutId           String?
  payout             LogisticsPayout?  @relation(fields: [payoutId], references: [id])
  notes              String?
  createdBy          String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status, pickupRegion])
  @@index([payoutId])
}

model LogisticsPayout {
  id                 String            @id @default(cuid())
  number             String            @unique
  logisticsPartnerId String
  logisticsPartner   LogisticsPartner  @relation(fields: [logisticsPartnerId], references: [id])
  amountCents        Int
  status             PayoutStatus      @default(PENDING)
  paymentReference   String?
  notes              String?
  createdBy          String
  paidAt             DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deliveries         DeliveryRequest[]
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amountCents Int
  date        DateTime
  notes       String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model AuctionSession {
  id          String               @id @default(cuid())
  slug        String               @unique
  title       String
  description String
  scheduledAt DateTime
  closedAt    DateTime?
  status      AuctionSessionStatus @default(UPCOMING)
  createdBy   String               @default("admin")
  createdAt   DateTime             @default(now())
  videoType   String?
  videoUrl    String?
  streamKey   String?
  photos      String[]
  bannerImage String?
  thumbnail   String?
  maxBidders  Int?

  lots          AuctionLot[]
  registrations AuctionRegistration[]
  results       AuctionResult[]

  @@index([status, scheduledAt])
}

model AuctionLot {
  id                 String           @id @default(cuid())
  sessionId          String
  livestockListingId String?
  lotNumber          Int
  title              String
  description        String
  species            String?
  breed              String?
  quantity           Int              @default(1)
  gender             String?
  weightKg           Int?
  region             String?
  location           String?
  healthStatus       String?
  images             String[]
  documents          String[]
  startingPriceCents Int
  reservePriceCents  Int?
  currentBidCents    Int              @default(0)
  winnerName         String?
  winnerEmail        String?
  status             AuctionLotStatus @default(PENDING)

  session AuctionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  bids    AuctionBid[]

  @@unique([sessionId, lotNumber])
  @@index([status])
}

model AuctionBid {
  id          String   @id @default(cuid())
  lotId       String
  bidderName  String
  bidderEmail String
  amountCents Int
  createdAt   DateTime @default(now())

  lot AuctionLot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([lotId, createdAt])
}

model AuctionRegistration {
  id              String    @id @default(cuid())
  sessionId       String
  fullName        String
  email           String
  phone           String
  idNumber        String
  physicalAddress String
  city            String
  province        String
  postalCode      String
  bankName        String?
  accountNumber   String?
  biddingNumber   String    @unique
  status          String    @default("PENDING")
  depositPaid     Boolean   @default(false)
  termsAccepted   Boolean   @default(false)
  adminNotes      String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())

  session AuctionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([biddingNumber])
}

model AuctionResult {
  id            String    @id @default(cuid())
  sessionId     String
  lotId         String
  lotNumber     Int
  lotTitle      String
  winnerEmail   String?
  biddingNumber String?
  winningBid    Int?
  reserveMet    Boolean   @default(false)
  totalBids     Int       @default(0)
  startPrice    Int
  lotStatus     String
  soldAt        DateTime?
  createdAt     DateTime  @default(now())

  session AuctionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

enum UserRole {
  CUSTOMER
  ADMIN
  FARMER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CategoryKind {
  LIVESTOCK
  PRODUCT
  BOTH
}

enum ListingStatus {
  ACTIVE
  DRAFT
  SOLD
  ARCHIVED
}

enum ProductStatus {
  ACTIVE
  DRAFT
  OUT_OF_STOCK
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  FAILED
}

enum AuctionSessionStatus {
  UPCOMING
  LIVE
  CLOSED
  CANCELLED
}

enum AuctionLotStatus {
  PENDING
  OPEN
  SOLD
  PASSED
  CANCELLED
}

model Sponsor {
  id               String            @id @default(cuid())
  companyName      String
  contactPerson    String
  email            String            @unique
  phone            String
  website          String?
  businessType     String
  package          String
  packageId        String?
  marketingPackage MarketingPackage? @relation(fields: [packageId], references: [id])
  targetProvinces  String[]
  marketingGoal    String
  logoUrl          String?
  bannerUrls       String[]
  brief            String?
  status           String            @default("PENDING")
  monthlyFee       Decimal?
  notes            String?
  approvedBy       String?
  approvedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  quotes           Quote[]
  invoices         Invoice[]
  creatives        SponsorCreative[]
}

enum CreativePlacement {
  HOMEPAGE
  SHOP
  LISTINGS
}

model SponsorCreative {
  id          String            @id @default(cuid())
  sponsorId   String
  sponsor     Sponsor           @relation(fields: [sponsorId], references: [id])
  placement   CreativePlacement
  imageUrl    String
  linkUrl     String?
  isActive    Boolean           @default(true)
  startDate   DateTime?
  endDate     DateTime?
  impressions Int               @default(0)
  clicks      Int               @default(0)
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([placement, isActive])
}

model MarketingPackage {
  id         String    @id @default(cuid())
  slug       String    @unique
  name       String
  monthlyFee Decimal
  badge      String?
  isCustom   Boolean   @default(false)
  features   String[]
  isActive   Boolean   @default(true)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  sponsors   Sponsor[]
  quotes     Quote[]
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

model Quote {
  id          String            @id @default(cuid())
  number      String            @unique
  sponsorId   String
  sponsor     Sponsor           @relation(fields: [sponsorId], references: [id])
  packageId   String?
  package     MarketingPackage? @relation(fields: [packageId], references: [id])
  description String
  amount      Decimal
  status      QuoteStatus       @default(DRAFT)
  validUntil  DateTime
  notes       String?
  createdBy   String
  sentAt      DateTime?
  respondedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  invoices    Invoice[]
}

enum InvoiceStatus {
  UNPAID
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id               String        @id @default(cuid())
  number           String        @unique
  sponsorId        String
  sponsor          Sponsor       @relation(fields: [sponsorId], references: [id])
  quoteId          String?
  quote            Quote?        @relation(fields: [quoteId], references: [id])
  description      String
  amount           Decimal
  status           InvoiceStatus @default(UNPAID)
  issueDate        DateTime      @default(now())
  dueDate          DateTime
  paidAt           DateTime?
  paymentReference String?
  periodLabel      String?
  notes            String?
  createdBy        String
  sentAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model DocumentCounter {
  id    String @id
  value Int    @default(0)
}

// ─── Mobile App Models ───────────────────────────────────────────────────────

model FarmerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  farmName    String   @default("")
  province    String   @default("")
  species     String[]
  farmCode    String?  @unique
  mobileRole  String   @default("FARMER")
  ownerUserId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([farmCode])
  @@index([ownerUserId])
}

model FarmInvite {
  id            String    @id @default(cuid())
  farmOwnerId   String
  farmName      String
  farmOwnerName String
  inviteCode    String    @unique
  role          String // FARM_MANAGER | FARM_WORKER
  status        String    @default("PENDING") // PENDING | ACCEPTED | REVOKED | EXPIRED
  expiresAt     DateTime
  acceptedBy    String?
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([farmOwnerId])
  @@index([status])
}

model FarmerActivityLog {
  id           String   @id @default(cuid())
  userId       String
  userName     String
  userRole     String
  farmId       String
  activityType String
  description  String
  entityId     String?
  entityType   String?
  entityName   String?
  metadata     String? // JSON string
  createdAt    DateTime @default(now())

  @@index([farmId, createdAt])
  @@index([userId])
}

model AppContent {
  id              String    @id @default(cuid())
  type            String
  title           String
  message         String?
  content         String?
  category        String?
  priority        String    @default("NORMAL")
  imageUrl        String?
  linkUrl         String?
  sponsorName     String?
  targetProvinces String[]
  targetSpecies   String[]
  status          String    @default("ACTIVE")
  sendPush        Boolean   @default(false)
  startDate       DateTime?
  endDate         DateTime?
  scheduledDate   DateTime?
  isDeleted       Boolean   @default(false)
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ContentView {
  id        String   @id @default(cuid())
  contentId String
  farmerId  String
  viewedAt  DateTime @default(now())

  @@index([contentId])
  @@index([farmerId])
}

model ContentDismissal {
  id          String   @id @default(cuid())
  contentId   String
  farmerId    String
  dismissedAt DateTime @default(now())

  @@unique([contentId, farmerId])
  @@index([farmerId])
}

model AppSettings {
  id                 String   @id @default(cuid())
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  minimumAppVersion  String   @default("1.0.0")
  supportWhatsApp    String?
  supportEmail       String?
  maxAnnouncements   Int      @default(1)
  maxBanners         Int      @default(2)
  sessionTimeout     Int      @default(15)
  updatedAt          DateTime @updatedAt
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model FarmerAnimal {
  id                 String    @id @default(cuid())
  localId            String?   @unique
  farmerId           String
  tagNumber          String?
  name               String?
  species            String
  breed              String?
  gender             String?
  dateOfBirth        DateTime?
  weight             Decimal?
  bodyConditionScore Int?
  colour             String?
  microchipId        String?
  source             String?
  purchasePrice      Decimal?
  dateAcquired       DateTime?
  auctionHouse       String?
  sellerName         String?
  prevFarm           String?
  camp               String?
  notes              String?
  status             String    @default("ACTIVE")
  isDeleted          Boolean   @default(false)
  photos             String[]
  healthStatus       String    @default("HEALTHY")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([farmerId, isDeleted])
  @@index([farmerId, species])
}

model FarmerHealthRecord {
  id           String    @id @default(cuid())
  animalId     String
  farmerId     String
  eventType    String
  description  String?
  diagnosis    String?
  treatment    String?
  vetName      String?
  severity     String?
  cost         Decimal?
  followUpDate DateTime?
  documents    String[]
  eventDate    DateTime
  status       String    @default("pending")
  createdAt    DateTime  @default(now())

  @@index([animalId])
  @@index([farmerId])
}

model FarmerTransaction {
  id            String   @id @default(cuid())
  farmerId      String
  type          String
  category      String
  amount        Decimal
  vatAmount     Decimal  @default(0)
  description   String?
  animalId      String?
  supplier      String?
  invoiceNumber String?
  date          DateTime
  createdAt     DateTime @default(now())

  @@index([farmerId])
  @@index([farmerId, date])
}

model FarmerWeightRecord {
  id                 String   @id @default(cuid())
  animalId           String
  farmerId           String
  weight             Decimal
  bodyConditionScore Int?
  notes              String?
  recordedDate       DateTime
  createdAt          DateTime @default(now())

  @@index([animalId])
}

model FarmerVaccination {
  id             String    @id @default(cuid())
  animalId       String
  farmerId       String
  vaccineName    String
  batchNumber    String?
  administeredBy String?
  vetName        String?
  cost           Decimal?
  vaccinatedDate DateTime?
  nextDueDate    DateTime?
  status         String    @default("SCHEDULED")
  notes          String?
  createdAt      DateTime  @default(now())

  @@index([animalId])
  @@index([farmerId])
  @@index([nextDueDate])
}

model PushNotificationLog {
  id           String    @id @default(cuid())
  title        String
  message      String
  target       String
  targetValue  String?
  sentCount    Int       @default(0)
  sentBy       String
  scheduleTime DateTime?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
}

model MarketPriceCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  priceData String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ── Mobile App: Camp Management ───────────────────────────────────────────────

model FarmerCamp {
  id                  String   @id @default(cuid())
  localId             String?  @unique // mobile-generated UUID for dedup
  farmerId            String
  name                String
  number              String?
  hectares            Decimal?
  forageType          String?
  currentStatus       String   @default("RESTING")
  maxCarryingCapacity Int?
  restingDaysRequired Int      @default(42)
  gpsCoordinates      String?
  notes               String?
  isDeleted           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([farmerId])
  @@index([farmerId, isDeleted])
}

model FarmerCampCount {
  id              String   @id @default(cuid())
  localId         String?
  campId          String
  farmerId        String
  countedByUserId String
  countedByName   String
  countedByRole   String
  countDate       DateTime
  expectedCount   Int?
  actualCount     Int
  variance        Int?
  varianceNotes   String?
  countMethod     String   @default("MANUAL")
  bullsCount      Int?
  cowsCount       Int?
  heifersCount    Int?
  calvesCount     Int?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([campId])
  @@index([farmerId])
}

model FarmerCampMovement {
  id            String   @id @default(cuid())
  localId       String?
  farmerId      String
  fromCampId    String?
  fromCampName  String?
  toCampId      String
  toCampName    String
  animalIds     String // JSON array of animal IDs
  headCount     Int
  movedByUserId String
  movedByName   String
  movedByRole   String
  movementDate  DateTime
  reason        String
  notes         String?
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([farmerId])
  @@index([toCampId])
}

// Bull turn-in/turnout — which breeding male(s) were put with a camp's
// females and when they were put in/removed, for calving-window and likely-
// sire tracking. Multi-sire camps are normal practice, so bullIds is a JSON
// array like FarmerCampMovement.animalIds.
model FarmerBullTurnout {
  id                    String    @id @default(cuid())
  localId               String?   @unique
  farmerId              String
  campId                String
  campName              String
  bullIds               String // JSON array of animal IDs
  bullTags              String // JSON array of tags, for display without a join
  dateIn                DateTime
  dateOut               DateTime?
  expectedCalvingStart  DateTime?
  expectedCalvingEnd    DateTime?
  recordedByUserId      String
  recordedByName        String
  recordedByRole        String
  notes                 String?
  isDeleted             Boolean   @default(false)
  createdAt             DateTime  @default(now())

  @@index([farmerId])
  @@index([campId])
}

model FarmerMedicine {
  id                   String   @id @default(cuid())
  localId              String?  @unique
  farmerId             String
  name                 String
  category             String
  manufacturer         String?
  withdrawalPeriodDays Int?
  dosageUnit           String?
  standardDosage       Decimal?
  storageInstructions  String?
  notes                String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([farmerId])
}

model FarmerTreatment {
  id                   String    @id @default(cuid())
  localId              String?   @unique
  animalId             String
  animalTag            String
  farmerId             String
  medicineId           String?
  medicineName         String
  medicineCategory     String
  treatmentType        String
  dosage               Decimal?
  dosageUnit           String?
  batchNumber          String?
  administeredByUserId String
  administeredByName   String
  administeredByRole   String
  treatmentDate        DateTime
  nextTreatmentDate    DateTime?
  withdrawalEndDate    DateTime?
  campId               String?
  campName             String?
  diagnosis            String?
  symptoms             String?
  vetName              String?
  prescriptionNumber   String?
  cost                 Decimal?
  notes                String?
  followUpRequired     Boolean   @default(false)
  followUpDate         DateTime?
  followUpCompleted    Boolean   @default(false)
  outcome              String?
  isDeleted            Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([animalId])
  @@index([farmerId])
  @@index([withdrawalEndDate])
}
