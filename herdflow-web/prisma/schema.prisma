model FarmerCampCount {
  id              String   @id @default(cuid())
  localId         String?
  campId          String
  farmerId        String
  countedByUserId String
  countedByName   String
  countedByRole   String
  countDate       DateTime
  expectedCount   Int?
  actualCount     Int
