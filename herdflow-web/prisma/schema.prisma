// Bull turn-in/turnout — which breeding male(s) were put with a camp's
// females and when they were put in/removed, for calving-window and likely-
// sire tracking. Multi-sire camps are normal practice, so bullIds is a JSON
// array like FarmerCampMovement.animalIds.
model FarmerBullTurnout {
  id                   String    @id @default(cuid())
  localId              String?   @unique
  farmerId             String
  campId               String
  campName             String
  bullIds              String // JSON array of animal IDs
  bullTags             String // JSON array of tags, for display without a join
  dateIn               DateTime
  dateOut              DateTime?
  expectedCalvingStart DateTime?
  expectedCalvingEnd   DateTime?
  recordedByUserId     String
  recordedByName       String
  recordedByRole       String
  notes                String?
  isDeleted            Boolean   @default(false)
  createdAt            DateTime  @default(now())

  @@index([farmerId])
  @@index([campId])
}

model FarmerMedicine {
  id                   String   @id @default(cuid())
  localId              String?  @unique
  farmerId             String
  name                 String
  category             String
  manufacturer         String?
  withdrawalPeriodDays Int?
  dosageUnit           String?
