# ── Domain & Public URLs ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.herdflow.co.za

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/herdflow_web?schema=public

# ── PayFast Configuration ──────────────────────────────────────
# Get MERCHANT_ID and MERCHANT_KEY from PayFast dashboard
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
# Sandbox: https://sandbox.payfast.co.za/eng/process
# Live: https://www.payfast.co.za/eng/process
PAYFAST_PROCESS_URL=https://sandbox.payfast.co.za/eng/process
PAYFAST_ITN_URL=https://www.herdflow.co.za/api/payfast/notify
# Set to "false" to go live with real payments. Defaults to sandbox mode.
PAYFAST_SANDBOX=true

# ── Cron ────────────────────────────────────────────────────────
# Shared secret checked on the Authorization header of /api/cron/* routes
# (e.g. Render's scheduled job hitting /api/cron/release-funds).
CRON_SECRET=your-long-random-cron-secret-here

# ── Digital Product Storage (S3-compatible) ────────────────────
# Required before digital product downloads can go live. Works with real
# AWS S3 (leave S3_ENDPOINT blank) or Cloudflare R2 / MinIO / any other
# S3-compatible provider (set S3_ENDPOINT to that provider's endpoint URL).
S3_ENDPOINT=
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Admin Credentials ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
ADMIN_SESSION_SECRET=your-long-random-secret-here
