# ── Domain & Public URLs ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.herdflow.co.za

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/herdflow_web?schema=public

# ── PayFast Configuration ──────────────────────────────────────
# Get MERCHANT_ID and MERCHANT_KEY from PayFast dashboard
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
# Sandbox: https://sandbox.payfast.co.za/eng/process
# Live: https://www.payfast.co.za/eng/process
PAYFAST_PROCESS_URL=https://sandbox.payfast.co.za/eng/process
PAYFAST_ITN_URL=https://www.herdflow.co.za/api/payfast/notify
# Set to "false" to go live with real payments. Defaults to sandbox mode.
PAYFAST_SANDBOX=true

# ── Cron ────────────────────────────────────────────────────────
# Shared secret checked on the Authorization header of /api/cron/* routes
# (e.g. Render's scheduled job hitting /api/cron/release-funds).
CRON_SECRET=your-long-random-cron-secret-here

# ── Digital Product Storage (S3-compatible) ────────────────────
# Required before digital product downloads can go live. Works with real
# AWS S3 (leave S3_ENDPOINT blank) or Cloudflare R2 / MinIO / any other
# S3-compatible provider (set S3_ENDPOINT to that provider's endpoint URL).
S3_ENDPOINT=
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Admin Credentials ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234
ADMIN_SESSION_SECRET=your-long-random-secret-here

# ── Sentry Error Monitoring ─────────────────────────────────────
# DSN from your Sentry project settings. Leave both blank to disable
# (Sentry.init is also gated on NODE_ENV=production in the config files).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Only needed to upload source maps at build time (CI/production builds).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── AI Vision (receipt scanning, animal-health triage, pasture advisory) ──
# From console.anthropic.com. Without this, /api/app/vision/analyze returns
# 503 "Vision analysis is not configured" for all three features.
ANTHROPIC_API_KEY=

# ── Weather (mobile Weather screen + AI pasture advisory) ──────
# Free classic Current Weather + 5 Day Forecast API key from
# home.openweathermap.org/api_keys -- NOT the paid One Call API 3.0 key.
# Without this, /api/app/weather returns 503 "Weather data unavailable".
WEATHER_API_KEY=

# ── Satellite Vegetation Health (NDVI, via Copernicus/Sentinel-2) ──
# OAuth2 client from a Sentinel Hub / Copernicus Data Space Ecosystem
# account (dataspace.copernicus.eu) -- Dashboard > User Settings > OAuth clients.
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
