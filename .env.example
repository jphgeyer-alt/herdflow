# Website frontend environment
VITE_SITE_URL=http://localhost:4173
VITE_MARKETPLACE_URL=http://localhost:4173/marketplace
VITE_APP_DOWNLOAD_URL=https://expo.io/builds

# Website backend (admin + website changes)
WEBSITE_API_PORT=4174
WEBSITE_DATA_FILE=server/data/herdflow-website.json
WEBSITE_STATIC_DIR=dist

# App backend (mobile app changes)
APP_API_PORT=4175
APP_DATA_FILE=server/data/herdflow-app.json
APP_DISABLE_STATIC=true

# Optional payment provider base URLs
STRIPE_CHECKOUT_URL=
PAYFAST_CHECKOUT_URL=

# Optional cloud database (Postgres)
DATABASE_URL=
DATABASE_SSL=true

# Kilo Code planning provider (Anthropic Claude)
ANTHROPIC_API_KEY=
KILO_PROVIDER=anthropic
KILO_MODEL=claude-sonnet-latest
