{
  "name": "herdflow-expo",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "web": "expo start --web",
    "generate:assets": "expo prebuild",
    "prebuild": "expo prebuild",
    "eas:install": "npm install -g eas-cli",
    "eas:build:preview": "eas build --platform android --profile preview",
    "eas:build:production": "eas build --platform android --profile production",
    "eas:status": "eas build:list --limit 10",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "~48.0.21",
    "expo-status-bar": "~1.4.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.71.14",
    "expo-splash-screen": "~0.18.2",
    "@react-native-async-storage/async-storage": "1.17.11",
    "@react-native-community/datetimepicker": "^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "babel-preset-expo": "^9.2.0"
  },
  "version": "1.0.0"
}
